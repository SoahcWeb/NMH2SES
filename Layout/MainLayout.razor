@using NHM.Services
@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<div class="app-shell">
    <header class="app-header">
        <div class="app-header__inner">
            <a class="brand-link" href="">
                <span class="brand-link__badge">NH</span>
                <span class="brand-link__copy">
                    <span class="brand-link__title">NHM</span>
                    <span class="brand-link__subtitle">Hub de découverte de films</span>
                </span>
            </a>

            <NavMenu />

            <div class="auth-toolbar">
                @if (AuthService.IsAuthenticated())
                {
                    <span class="auth-toolbar__welcome">Bienvenue, @AuthService.GetCurrentUser()</span>
                    <button type="button" class="app-button app-button--secondary" @onclick="HandleLogout">Déconnexion</button>
                }
                else
                {
                    <NavLink class="app-button app-button--primary" href="login">Connexion</NavLink>
                }
            </div>
        </div>
    </header>

    <main class="app-shell__main">
        <div class="app-shell__content">
            @Body
        </div>
    </main>
</div>

@code {
    private void HandleLogout()
    {
        AuthService.Logout();
        NavigationManager.NavigateTo("/");
    }
}
