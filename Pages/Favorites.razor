@page "/favorites"
@using NHM.Models
@using NHM.Services
@inject FavoriteService FavoriteService

<PageTitle>Favorites</PageTitle>

<h1 class="mb-4">Favorite Movies</h1>

@if (favoriteMovies.Count == 0)
{
    <div class="alert alert-info">
        No favorite movies yet.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var movie in favoriteMovies)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(movie.PosterPath))
                    {
                        <img src="@GetPosterUrl(movie.PosterPath)"
                             class="card-img-top"
                             alt="@movie.Title"
                             style="height: 360px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-light text-muted"
                             style="height: 360px;">
                            No image
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@movie.Title</h5>

                        <button class="btn btn-danger mt-auto"
                                @onclick="() => RemoveFavorite(movie.Id)">
                            Remove
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Movie> favoriteMovies = new();

    protected override void OnInitialized()
    {
        LoadFavorites();
    }

    private void LoadFavorites()
    {
        favoriteMovies = FavoriteService.GetAll().ToList();
    }

    private void RemoveFavorite(int movieId)
    {
        FavoriteService.Remove(movieId);
        LoadFavorites();
    }

    private static string GetPosterUrl(string posterPath)
    {
        return $"https://image.tmdb.org/t/p/w500{posterPath}";
    }
}
