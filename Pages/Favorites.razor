@page "/favorites"
@using System.Reflection
@using System.Text.Json
@using NHM.Models
@using NHM.Services
@inject FavoriteService FavoriteService
@inject AuthService AuthService
@inject IJSRuntime JS

<PageTitle>Favoris</PageTitle>

<div class="favorites-layout">

    <h1 class="home-title">Tes films favoris</h1>

    <div class="section-divider"></div>

    @if (!AuthService.IsAuthenticated())
    {
        <div class="surface-card surface-card--centered">
            <h2>Accès requis</h2>
            <p>Tu dois être connecté pour accéder à tes favoris.</p>

            <a class="app-button app-button--primary" href="/login">
                Se connecter
            </a>
        </div>
    }
    else if (favoriteMovies.Count == 0)
    {
        <div class="surface-card surface-card--centered">
            <h2>Aucun favori</h2>
            <p>Tu n’as pas encore ajouté de films à tes favoris.</p>

            <a class="app-button app-button--secondary" href="/movies">
                Explorer les films
            </a>
        </div>
    }
    else
    {
        <div class="favorites-grid">

            @foreach (var favorite in favoriteMovies)
            {
                <div class="surface-card favorite-card">

                    @if (!string.IsNullOrWhiteSpace(favorite.Movie.PosterPath))
                    {
                        <img class="favorite-poster"
                             src="@GetPosterUrl(favorite.Movie.PosterPath)"
                             alt="@favorite.Movie.Title" />
                    }
                    else
                    {
                        <div class="favorite-placeholder">
                            Aucune image
                        </div>
                    }

                    <div class="favorite-content">

                        <h2 class="favorite-title">@favorite.Movie.Title</h2>

                        <label>Commentaire</label>
                        <input class="form-control"
                               @bind="favorite.UserComment"
                               placeholder="Ajoute ton avis..." />

                        <label>Note (1 - 10)</label>
                        <InputNumber class="form-control"
                                     @bind-Value="favorite.UserRating"
                                     min="1"
                                     max="10" />

                        @if (saveMessages.TryGetValue(favorite.Movie.Id, out var message))
                        {
                            <p class="favorite-success">@message</p>
                        }

                        <div class="favorite-actions">
                            <button class="app-button app-button--primary"
                                    @onclick="() => SaveMovieChangesAsync(favorite)">
                                Enregistrer
                            </button>

                            <button class="app-button app-button--secondary"
                                    @onclick="() => RemoveFavoriteAsync(favorite.Movie.Id)">
                                Supprimer
                            </button>
                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

@code {
    private List<EditableFavoriteMovie> favoriteMovies = new();
    private Dictionary<int, FavoriteMovieEdit> savedEdits = new();
    private Dictionary<int, string> saveMessages = new();
    private bool metadataLoaded;

    protected override void OnInitialized()
    {
        LoadFavorites();
    }

    protected override void OnParametersSet()
    {
        if (AuthService.IsAuthenticated())
        {
            LoadFavorites();
            metadataLoaded = false;
        }
        else
        {
            favoriteMovies.Clear();
            savedEdits.Clear();
            saveMessages.Clear();
            metadataLoaded = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (AuthService.IsAuthenticated() && !metadataLoaded)
        {
            metadataLoaded = true;
            await LoadFavoriteEditsAsync();
            LoadFavorites();
            StateHasChanged();
        }
    }

    private void LoadFavorites()
    {
        favoriteMovies = FavoriteService
            .GetAll()
            .Select(movie =>
            {
                savedEdits.TryGetValue(movie.Id, out var edit);

                return new EditableFavoriteMovie
                {
                    Movie = movie,
                    UserComment = edit?.UserComment ?? string.Empty,
                    UserRating = edit?.UserRating ?? 1
                };
            })
            .ToList();
    }

    private async Task SaveMovieChangesAsync(EditableFavoriteMovie favorite)
    {
        favorite.UserRating = Math.Clamp(favorite.UserRating, 1, 10);

        savedEdits[favorite.Movie.Id] = new FavoriteMovieEdit
        {
            UserComment = favorite.UserComment ?? string.Empty,
            UserRating = favorite.UserRating
        };

        await PersistFavoriteEditsAsync();
        InvokeFavoriteServiceSave();
        saveMessages[favorite.Movie.Id] = "Modifications enregistrées.";
    }

    private async Task RemoveFavoriteAsync(int movieId)
    {
        FavoriteService.Remove(movieId);
        savedEdits.Remove(movieId);
        saveMessages.Remove(movieId);
        LoadFavorites();
        await PersistFavoriteEditsAsync();
    }

    private static string GetPosterUrl(string posterPath)
        => $"https://image.tmdb.org/t/p/w500{posterPath}";

    private async Task LoadFavoriteEditsAsync()
    {
        var json = await JS.InvokeAsync<string?>("localStorage.getItem", GetFavoriteEditsStorageKey());

        savedEdits = !string.IsNullOrWhiteSpace(json)
            ? JsonSerializer.Deserialize<Dictionary<int, FavoriteMovieEdit>>(json) ?? new()
            : new();
    }

    private async Task PersistFavoriteEditsAsync()
    {
        var json = JsonSerializer.Serialize(savedEdits);
        await JS.InvokeVoidAsync("localStorage.setItem", GetFavoriteEditsStorageKey(), json);
    }

    private string GetFavoriteEditsStorageKey()
        => $"favorite-movie-edits:{AuthService.GetCurrentUser()}";

    private void InvokeFavoriteServiceSave()
    {
        var saveMethod = typeof(FavoriteService)
            .GetMethod("Save", BindingFlags.Instance | BindingFlags.NonPublic);

        saveMethod?.Invoke(FavoriteService, null);
    }

    private sealed class EditableFavoriteMovie
    {
        public required Movie Movie { get; init; }
        public string UserComment { get; set; } = string.Empty;
        public int UserRating { get; set; } = 1;
    }

    private sealed class FavoriteMovieEdit
    {
        public string UserComment { get; set; } = string.Empty;
        public int UserRating { get; set; } = 1;
    }
}