@page "/"
@using NHM.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Accueil</PageTitle>

<div class="home-layout-centered">

    <main class="home-main-centered">

        <!-- TITRE -->
        <h1 class="home-title">
            Explorez, organisez et profitez <br /> de vos films et séries
        </h1>

        @if (AuthService.IsAuthenticated())
        {
            <p class="home-desc">
                Namasté <strong>@AuthService.GetCurrentUser()</strong> 👋
            </p>

            <div class="hero-actions">
                <a class="btn btn-primary" href="/favorites">Mes favoris</a>
                <a class="btn btn-secondary" href="/movies">Explorer</a>
                <button class="btn btn-danger" @onclick="Logout">Logout</button>
            </div>
        }
        else
        {
            <p class="home-desc">
                Connecte-toi pour accéder à tes favoris et ton espace personnel.
            </p>

            <div class="hero-actions">
                <a class="btn btn-primary" href="/login">Se connecter</a>
                <a class="btn btn-secondary" href="/movies">Explorer</a>
            </div>
        }

        <!-- SEPARATOR -->
        <div class="section-divider"></div>

        <!-- FEATURES -->
        <div class="home-features-two">

            <div class="feature-card">
                <img src="/images/search001.png" class="feature-icon" />
                <h2>Moteur de recherche</h2>
                <p>
                    Trouve rapidement films et séries avec une navigation fluide et simple.
                </p>
            </div>

            <div class="feature-card">
                <img src="/images/favoris001.png" class="feature-icon" />
                <h2>Favoris</h2>
                <p>
                    Sauvegarde tes films et garde-les accessibles à tout moment.
                </p>
            </div>

        </div>

        <!-- SEPARATOR -->
        <div class="section-divider"></div>

        <!-- BIBLIOTHÈQUE -->
        <div class="feature-card library-card">
            <img src="/images/library001.png" class="feature-icon" />

            <h2>Nouveauté – Ma bibliothèque</h2>
            <p>
                Organise tes films et séries dans une bibliothèque personnelle simple et efficace.
            </p>
        </div>

        <!-- SEPARATOR -->
        <div class="section-divider"></div>

        <!-- FIN -->
        <div class="final-section">
            <p>
                Rejoins <strong>Nethra Media Hub</strong> pour profiter d’une expérience cinéma simple et fluide.
            </p>

            <a class="btn btn-primary" href="/login">Commencer</a>
        </div>

    </main>

</div>

@code {
    private void Logout()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/");
    }
}