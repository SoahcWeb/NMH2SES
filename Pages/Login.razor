@page "/login"
@using NHM.Services
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Connexion</PageTitle>

<div class="favorites-layout">

    <h1 class="home-title">Connexion</h1>

    <div class="section-divider"></div>

    <div class="surface-card surface-card--centered login-card">

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="login-error">@errorMessage</p>
        }

        <label>Nom d'utilisateur</label>
        <input class="form-control"
               @bind="username"
               placeholder="Entre ton nom..." />

        <label>Mot de passe</label>
        <input class="form-control"
               type="password"
               @bind="password"
               placeholder="••••••••" />

        <div class="favorite-actions">
            <button class="app-button app-button--primary"
                    @onclick="HandleLogin">
                Se connecter
            </button>
        </div>

    </div>

</div>

@code {
    private string username = string.Empty;
    private string password = string.Empty;
    private string? errorMessage;

    private void HandleLogin()
    {
        var success = AuthService.Login(username, password);

        if (success)
        {
            errorMessage = null;
            NavigationManager.NavigateTo("/movies");
        }
        else
        {
            errorMessage = "Veuillez saisir un nom d'utilisateur et un mot de passe.";
        }
    }
}