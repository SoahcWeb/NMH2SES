@page "/movie-details/{id:int}"
@using NHM.Models
@using NHM.Services
@inject TmdbService TmdbService
@inject FavoriteService FavoriteService
@inject NavigationManager NavigationManager

<PageTitle>Movie Details</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            @if (isLoading)
            {
                <div class="text-center py-4">
                    <p class="mb-0">Loading movie details...</p>
                </div>
            }
            else if (movie is null)
            {
                <div class="alert alert-warning mb-3">
                    Movie not found.
                </div>

                <div class="d-grid d-sm-flex gap-2">
                    <button class="btn btn-secondary" @onclick="BackToMovies">
                        Back to movies
                    </button>
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="row g-0">
                        <div class="col-md-4">
                            @if (!string.IsNullOrWhiteSpace(movie.PosterPath))
                            {
                                <img src="@GetPosterUrl(movie.PosterPath)"
                                     alt="@movie.Title"
                                     class="img-fluid rounded-top rounded-md-start"
                                     style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center bg-light text-muted h-100"
                                     style="min-height: 400px;">
                                    No poster
                                </div>
                            }
                        </div>

                        <div class="col-md-8">
                            <div class="card-body p-4">
                                <h1 class="card-title mb-3">@movie.Title</h1>
                                <p class="card-text mb-4">@movie.Overview</p>

                                <div class="row g-3 mb-4">
                                    <div class="col-sm-6">
                                        <div class="border rounded p-3 h-100">
                                            <strong>Vote average</strong>
                                            <div>@movie.VoteAverage.ToString("0.0")</div>
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="border rounded p-3 h-100">
                                            <strong>Vote count</strong>
                                            <div>@movie.VoteCount</div>
                                        </div>
                                    </div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(message))
                                {
                                    <div class="alert alert-success mb-4">@message</div>
                                }

                                <div class="d-grid gap-2 d-sm-flex">
                                    <button class="btn btn-primary"
                                            @onclick="AddToFavorites">
                                        Add to favorites
                                    </button>
                                    <button class="btn btn-secondary"
                                            @onclick="BackToMovies">
                                        Back to movies
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Movie? movie;
    private bool isLoading = true;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            movie = await TmdbService.GetMovieDetailsAsync(Id);
        }
        catch
        {
            movie = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddToFavorites()
    {
        if (movie is null)
        {
            return;
        }

        FavoriteService.Add(movie);
        message = $"\"{movie.Title}\" added to favorites.";
    }

    private void BackToMovies()
    {
        NavigationManager.NavigateTo("/movies");
    }

    private static string GetPosterUrl(string posterPath)
    {
        return $"https://image.tmdb.org/t/p/w500{posterPath}";
    }
}
