@page "/movie-details/{id:int}"
@using NHM.Models
@using NHM.Services
@inject TmdbService TmdbService
@inject FavoriteService FavoriteService
@inject NavigationManager NavigationManager

<PageTitle>Détails du film</PageTitle>

<div class="favorites-layout">

    <h1 class="home-title">Détails du film</h1>

    <div class="section-divider"></div>

    @if (isLoading)
    {
        <div class="surface-card surface-card--centered">
            <p>Chargement des détails du film...</p>
        </div>
    }
    else if (movie is null)
    {
        <div class="surface-card surface-card--centered">
            <h2>Film introuvable</h2>

            <button class="app-button app-button--secondary"
                    @onclick="BackToMovies">
                Retour aux films
            </button>
        </div>
    }
    else
    {
        <div class="surface-card movie-details-card"
             style="background-image: url('@GetPosterUrl(movie?.PosterPath ?? "")');">

            <!-- IMAGE -->
            @if (!string.IsNullOrWhiteSpace(movie.PosterPath))
            {
                <img class="favorite-poster"
                     src="@GetPosterUrl(movie.PosterPath)"
                     alt="@movie.Title" />
            }
            else
            {
                <div class="favorite-placeholder">
                    Aucune affiche
                </div>
            }

            <!-- CONTENU -->
            <div class="favorite-content">

                <h2 class="favorite-title">@movie.Title</h2>

                <p class="movie-overview">
                    @movie.Overview
                </p>

                <!-- INFOS -->
                <div class="movie-stats">

                    <div class="stat-box">
                        <strong>Note</strong>
                        <span>@movie.VoteAverage.ToString("0.0")</span>
                    </div>

                    <div class="stat-box">
                        <strong>Votes</strong>
                        <span>@movie.VoteCount</span>
                    </div>

                </div>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <p class="favorite-success">@message</p>
                }

                <!-- ACTIONS -->
                <div class="favorite-actions">

                    <button class="app-button app-button--primary"
                            @onclick="AddToFavorites">
                        Ajouter aux favoris
                    </button>

                    <button class="app-button app-button--secondary"
                            @onclick="BackToMovies">
                        Retour
                    </button>

                </div>

            </div>

        </div>
    }

</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Movie? movie;
    private bool isLoading = true;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            movie = await TmdbService.GetMovieDetailsAsync(Id);
        }
        catch
        {
            movie = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddToFavorites()
    {
        if (movie is null) return;

        FavoriteService.Add(movie);
        message = $"\"{movie.Title}\" ajouté aux favoris.";
    }

    private void BackToMovies()
    {
        NavigationManager.NavigateTo("/movies");
    }

    private static string GetPosterUrl(string posterPath)
        => $"https://image.tmdb.org/t/p/w500{posterPath}";
}