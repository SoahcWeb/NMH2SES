@page "/movies"
@using NHM.Models
@using NHM.Services
@inject TmdbService TmdbService
@inject FavoriteService FavoriteService
@inject NavigationManager NavigationManager

<PageTitle>Films</PageTitle>

<div class="favorites-layout">

    <h1 class="home-title">Explorer les films</h1>

    <div class="section-divider"></div>

    <!-- SEARCH -->
    <div class="surface-card">

        <label>Rechercher un film</label>

        <input class="form-control"
               placeholder="Tape un titre..."
               @bind="searchTitle" />

        <div class="favorite-actions">
            <button class="app-button app-button--primary"
                    @onclick="SearchMoviesAsync">
                Rechercher
            </button>
        </div>

    </div>

    <div class="section-divider"></div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="surface-card surface-card--centered">
            <p>@message</p>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="surface-card surface-card--centered">
            <p style="color: #ff668d">@errorMessage</p>
        </div>
    }

    @if (isLoading)
    {
        <div class="surface-card surface-card--centered">
            <p>Chargement des films...</p>
        </div>
    }
    else if (movies.Count > 0)
    {
        <div class="favorites-grid">

            @foreach (var movie in movies)
            {
                <div class="surface-card favorite-card">

                    @if (!string.IsNullOrWhiteSpace(movie.PosterPath))
                    {
                        <img class="favorite-poster"
                             src="@GetPosterUrl(movie.PosterPath)"
                             alt="@movie.Title" />
                    }
                    else
                    {
                        <div class="no-image">
                            Aucune image
                        </div>
                    }

                    <div class="favorite-content">

                        <h2 class="favorite-title">@movie.Title</h2>

                        <p>⭐ @movie.VoteAverage.ToString("0.0")</p>

                        <div class="favorite-actions">

                            <button class="app-button app-button--secondary"
                                    @onclick="() => GoToDetails(movie.Id)">
                                Détails
                            </button>

                            <button class="app-button app-button--primary"
                                    @onclick="() => AddToFavorites(movie)">
                                Favoris
                            </button>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

@code {
    private string searchTitle = string.Empty;
    private IReadOnlyList<Movie> movies = Array.Empty<Movie>();
    private bool isLoading;
    private string? message;
    private string? errorMessage;

    private async Task SearchMoviesAsync()
    {
        errorMessage = null;
        message = null;

        if (string.IsNullOrWhiteSpace(searchTitle))
        {
            movies = Array.Empty<Movie>();
            message = "Saisis un titre de film pour lancer la recherche.";
            return;
        }

        try
        {
            isLoading = true;
            movies = await TmdbService.SearchMoviesByTitleAsync(searchTitle.Trim());

            if (movies.Count == 0)
            {
                message = "Aucun film trouvé.";
            }
        }
        catch
        {
            movies = Array.Empty<Movie>();
            errorMessage = "Une erreur s'est produite lors du chargement des films.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddToFavorites(Movie movie)
    {
        FavoriteService.Add(movie);
        message = $"\"{movie.Title}\" ajouté aux favoris.";
        errorMessage = null;
    }

    private void GoToDetails(int movieId)
    {
        NavigationManager.NavigateTo($"/movie-details/{movieId}");
    }

    private static string GetPosterUrl(string posterPath)
    {
        return $"https://image.tmdb.org/t/p/w500{posterPath}";
    }
}